{
  "batch_name": "night_30runs",
  "base_config": "/home/bupt/wlh/ran/automation/config.example.json",
  "artifacts_root": "automation/batches",
  "continue_on_failure": true,
  "scenarios": [    
    {
      "name": "cache_super_light",
      "persistent_stress": true,
      "repeat": 10,
      "overrides": {
        "stress": {
          "enabled": true,
          "target": "local",
          "command": "taskset -c 8 stress-ng --cache 8 --cache-level 3 --timeout 6000s --metrics-brief"
        }
      }
    },
  {
    "name": "cache_medium",
    "persistent_stress": true,
    "repeat": 10,
    "overrides": {
      "stress": {
        "enabled": true,
        "target": "local",
        "command": "taskset -c 8-15 stress-ng --cache 16 --cache-level 3 --timeout 6000s --metrics-brief"
      }
    }
  },
    {
      "name": "no_cache",
      "persistent_stress": true,
      "repeat": 10
    }
  ]
}
